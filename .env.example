# Public client (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="supabase-anon-key"

# Shared Supabase defaults
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="supabase-anon-key"
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY="supabase-service-role-key"

# 3rd-party integrations
GITHUB_PAT=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""
TELEGRAM_ALLOWED_USERNAME=""

# Vault configuration
VAULT_PIN=2846
VAULT_SESSION_TTL_HOURS=24

# Notes:
# - The vault API uses SUPABASE_SERVICE_ROLE_KEY on the server only.
# - NEXT_PUBLIC_* values are safe for the browser but still required.
